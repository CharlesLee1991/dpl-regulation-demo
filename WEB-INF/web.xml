<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
           http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>DPL JSP Migration</display-name>
  <description>롯데중앙연구소 DPL ASP→JSP 마이그레이션</description>

  <!-- ── DB 커넥션풀 파라미터 ── -->
  <context-param>
    <param-name>DB_URL</param-name>
    <param-value>jdbc:sqlserver://DB_HOST:DB_PORT;databaseName=LSAFE;encrypt=false;trustServerCertificate=true</param-value>
  </context-param>
  <context-param>
    <param-name>DB_USER</param-name>
    <param-value>lsafe</param-value>
  </context-param>
  <context-param>
    <param-name>DB_PASS</param-name>
    <!-- 환경변수 주입: CATALINA_OPTS=-DDB_PASS=실제비밀번호 -->
    <param-value>${DB_PASS}</param-value>
  </context-param>
  <context-param>
    <param-name>DB_POOL_SIZE</param-name>
    <param-value>10</param-value>
  </context-param>

  <!-- ── DB Pool 초기화 리스너 ── -->
  <listener>
    <listener-class>db.DBPoolListener</listener-class>
  </listener>

  <!-- ── Servlet 매핑 ── -->
  <servlet>
    <servlet-name>RegulationServlet</servlet-name>
    <servlet-class>ctrl.RegulationServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>RegulationServlet</servlet-name>
    <url-pattern>/regulation/</url-pattern>
    <url-pattern>/regulation</url-pattern>
  </servlet-mapping>

  <!-- ── 기본 인코딩 ── -->
  <filter>
    <filter-name>EncodingFilter</filter-name>
    <filter-class>org.apache.catalina.filters.SetCharacterEncodingFilter</filter-class>
    <init-param>
      <param-name>encoding</param-name>
      <param-value>UTF-8</param-value>
    </init-param>
  </filter>
  <filter-mapping>
    <filter-name>EncodingFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>
</web-app>
